# ============================================
# BROKE N BUILT SERVICES - Environment Config
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ====== EMAIL NOTIFICATIONS ======
# When a client submits the contact form, an email will be sent.
# Choose ONE of the following options:

# Option 1: Gmail SMTP (App Password required)
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail"
# 4. Use that password below
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=brokenbuiltservices@gmail.com
# EMAIL_PASS=your-16-digit-app-password-here
# EMAIL_TO=brokenbuiltservices@gmail.com
# EMAIL_FROM=brokenbuiltservices@gmail.com

# Option 2: SendGrid (Free tier: 100 emails/day)
# 1. Sign up at https://sendgrid.com (free tier)
# 2. Create an API Key with "Mail Send" permission
# 3. Verify a sender email address
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=your-sendgrid-api-key-here
# EMAIL_TO=brokenbuiltservices@gmail.com
# EMAIL_FROM=your-verified-sender@example.com

# ====== AI CHATBOT ======
# Optional - If not set, the chatbot uses smart fallback responses.
# 
# Option A: OpenAI API Key (paid)
# OPENAI_API_KEY=sk-your-openai-api-key
#
# Option B: OpenRouter (has free models!)
# Get free credits at https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-your-openrouter-key

# ====== SERVER ======
# PORT=3000
